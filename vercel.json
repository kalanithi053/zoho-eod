{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/doc-json",
      "dest": "api/index.ts"
    },
    {
      "src": "/api/doc(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/track/sheet-to-report",
      "schedule": "12 9 * * *"
    }
  ]
}
